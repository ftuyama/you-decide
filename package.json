{
  "name": "silent-dungeon",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "check:engine-boundaries": "node scripts/check-engine-boundaries.mjs",
    "verify:refactor": "npm run check:engine-boundaries && npm run test",
    "validate:scenes": "node scripts/validate-scenes.mjs",
    "validate:unreachable": "node scripts/find-unreachable-scenes.mjs",
    "check:ascii-art": "node scripts/check-pending-ascii-art.mjs",
    "estimate:balance": "tsx scripts/balance-estimate.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "release:itch": "bash scripts/release-itch.sh",
    "release:itch:push": "bash scripts/release-itch.sh --push"
  },
  "devDependencies": {
    "@types/dompurify": "^3.0.5",
    "@types/node": "^25.5.2",
    "sharp": "^0.34.5",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "vite": "^8.0.1",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "dompurify": "^3.3.3",
    "marked": "^17.0.5",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  }
}
